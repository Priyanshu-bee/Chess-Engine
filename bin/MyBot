#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
if [ -x "/opt/homebrew/opt/openjdk/bin/java" ]; then
    JAVA_CMD="/opt/homebrew/opt/openjdk/bin/java"
elif /usr/libexec/java_home &> /dev/null; then
    JAVA_CMD="$(/usr/libexec/java_home)/bin/java"
else
    JAVA_CMD="java"
fi

exec "$JAVA_CMD" -XX:+UseG1GC -XX:MaxGCPauseMillis=20 -cp "$SCRIPT_DIR" execution.MyBot "$@"
